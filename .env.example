# --- Copy this file to .env.local and fill in real values ---

# Neon Postgres (serverless). Create a project at https://neon.tech (or Vercel > Storage > Postgres).
# Use the POOLED connection string. Must include ?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# OpenAI (your one-time hackathon credit code -> create an API key)
OPENAI_API_KEY="sk-..."
# Optional model override (default: gpt-4o). Must support vision + JSON output.
OPENAI_MODEL="gpt-4o"

# Tavily (shared hackathon code) — web search + external claim verification
TAVILY_API_KEY="tvly-..."

# GitHub (optional but recommended) — a classic PAT with public scope raises rate limits
GITHUB_TOKEN="ghp_..."

# ElevenLabs (optional) — audio memo readout only
ELEVENLABS_API_KEY=""
